# ══════════════════════════════════════════════════════════════
# Market Analysis — Microservices Configuration
# Copy this file to .env and fill in your credentials
# ══════════════════════════════════════════════════════════════

# ── Market Data APIs (Service A) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ── Notifications (Notification Gateway) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── Risk Parameters (Service B) ──
RISK_REWARD_RATIO=3.0
ATR_STOP_MULTIPLIER=1.5
ATR_VOLATILITY_THRESHOLD=2.0
TRAILING_STOP_PCT=0.02

# ── Portfolio (Service C) ──
INITIAL_BALANCE=10000.0

# ── Internal Service URLs (set automatically by docker-compose) ──
# DATA_INGESTION_URL=http://data-ingestion:8000
# QUANT_ENGINE_URL=http://quant-engine:8001
