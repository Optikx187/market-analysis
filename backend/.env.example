# Market Analysis Platform — Environment Configuration

# Database (default: SQLite local file)
DATABASE_URL=sqlite+aiosqlite:///./market_analysis.db

# Telegram Bot (optional — get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Discord Webhook (optional — create in Discord Channel Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# API Webhooks (managed via the dashboard Settings tab)
# Add webhook endpoints through the UI to receive trading signals as JSON POST requests.
# Each webhook can have an optional signing secret for HMAC-SHA256 payload verification.

# Binance API (optional — for enhanced crypto data; free tier works)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Alpaca API (optional — for enhanced stock data)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret

# Paper Trading
INITIAL_BALANCE=100000.0

# Strategy Parameters
RISK_REWARD_RATIO=3.0
ATR_STOP_MULTIPLIER=1.5
TRAILING_STOP_PCT=0.02
ATR_VOLATILITY_THRESHOLD=2.0
